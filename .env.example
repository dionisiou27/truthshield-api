# ============================================
# TruthShield API - Environment Configuration
# ============================================
# Copy this file to .env and fill in your API keys

# ============================================
# AI / LLM APIs
# ============================================

# OpenAI API - PAID
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# LLM model selection (model-agnostic; override without code changes).
# VERIFY the exact ids against your account before deploying — model ids change
# and old ones get retired (a retired id returns 404 and degrades the service):
#   curl -s https://api.openai.com/v1/models -H "Authorization: Bearer $OPENAI_API_KEY" \
#     | python -c "import json,sys;[print(m['id']) for m in json.load(sys.stdin)['data']]" | sort
# OPENAI_MODEL_CLASSIFICATION falls back to OPENAI_MODEL_GENERATION if unset.
OPENAI_MODEL_GENERATION=gpt-5.1
OPENAI_MODEL_CLASSIFICATION=gpt-5.4-nano

# ============================================
# FACT-CHECKING APIs
# ============================================

# Google Fact Check Tools API - FREE
# Get key: https://console.cloud.google.com/apis/credentials
# Enable: Fact Check Tools API
GOOGLE_API_KEY=your_google_api_key_here

# ClaimBuster API - FREE
# Get key: https://idir.uta.edu/claimbuster/api_key/
CLAIMBUSTER_API_KEY=your_claimbuster_api_key_here

# ============================================
# NEWS APIs
# ============================================

# NewsAPI - FREE TIER (100 requests/day)
# Get key: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ============================================
# ACADEMIC APIs
# ============================================

# CORE.ac.uk API - FREE
# Get key: https://core.ac.uk/services/api
CORE_API_KEY=your_core_api_key_here

# NOTE: PubMed, arXiv, Semantic Scholar need NO API key

# ============================================
# SOCIAL MEDIA APIs (optional)
# ============================================

TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

TIKTOK_USERNAME=
TIKTOK_PASSWORD=

# ============================================
# DATABASE & CACHE
# ============================================

DATABASE_URL=sqlite+aiosqlite:///./truthshield.db
REDIS_URL=redis://localhost:6379/0

# ============================================
# SECURITY (change these!)
# ============================================

SECRET_KEY=generate-a-random-secret-key
JWT_SECRET=generate-a-random-jwt-secret

# ============================================
# MONITORING (optional)
# ============================================

SENTRY_DSN=

# ============================================
# ENVIRONMENT
# ============================================

DEBUG=true
ENVIRONMENT=development

# SSL Verification - set to "true" to disable SSL certificate verification
# Only use in development environments with proxy/self-signed certificates
DISABLE_SSL_VERIFY=false
